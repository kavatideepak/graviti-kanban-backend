# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# DATABASE_URL — PostgreSQL connection string:
#   postgres://<user>:<password>@<host>:5432/<database>
# The password below is masked on purpose; the live value lives only in the
# local (gitignored) .env. This repo is public, so no real host/credentials
# are committed here.
DATABASE_URL=postgres://kanban_user:__DB_PASSWORD__@<db_host>:5432/graviti_kanban

# Port the API/Socket.IO server listens on.
PORT=4000

# Allowed browser origin for CORS + Socket.IO.
#   local dev:   http://localhost:5173
#   production:  https://kanban.synapsebygraviti.com
CLIENT_ORIGIN=http://localhost:5173
